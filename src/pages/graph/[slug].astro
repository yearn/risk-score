---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getGraphSlugs,
  getGraphBySlug,
  getGraphIndex,
  resolveCrossLink,
  expandCrossLinks,
  explorerUrl,
  type GraphCategory,
  type GraphEdge,
  type GraphNode,
} from "../../lib/graph";
import { getReportBySlug } from "../../lib/reports";
import { scoreColor, scoreTier } from "../../lib/colors";

export function getStaticPaths() {
  return getGraphSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const baseGraph = getGraphBySlug(slug!);
if (!baseGraph) return Astro.redirect("/reports/");

const graphIndex = getGraphIndex();
// Inline the downstream subgraph of each cross-linked node so a reviewer
// sees the strategies/dependencies behind external protocols on the same page.
const graph = expandCrossLinks(baseGraph, slug!);

const cyData = {
  nodes: graph.nodes.map((n: GraphNode) => {
    // Suppress cross-link affordance on nodes that were themselves inlined
    // from another graph — keeps drill-down strictly one level deep.
    const crossLinkEntry = n._inlinedFromSlug
      ? undefined
      : resolveCrossLink(n, graph.chain, slug!, graphIndex);
    let crossLink:
      | { slug: string; score: number; tier: string; color: string }
      | null = null;
    if (crossLinkEntry) {
      const report = getReportBySlug(crossLinkEntry.slug);
      if (report && report.finalScore > 0) {
        crossLink = {
          slug: crossLinkEntry.slug,
          score: report.finalScore,
          tier: scoreTier(report.finalScore),
          color: scoreColor(report.finalScore),
        };
      }
    }
    return {
      id: n.id,
      label: n.label,
      category: n.category,
      address: n.address ?? "",
      link: n.address ? explorerUrl(n.address, n.chain ?? graph.chain) : "",
      note: n.note ?? "",
      crossLink,
      inlinedFromSlug: n._inlinedFromSlug ?? null,
    };
  }),
  edges: graph.edges.map((e: GraphEdge, i: number) => ({
    id: `e${i}`,
    source: e.from,
    target: e.to,
    kind: e.kind,
    label: e.label ?? "",
  })),
};

const categoryLabels: Record<string, string> = Object.fromEntries(
  graph.categories.map((c) => [c.id, c.label]),
);

const usedKinds = Array.from(new Set(graph.edges.map((e) => e.kind)));
const usedCategories: GraphCategory[] = graph.categories.filter((c) =>
  graph.nodes.some((n) => n.category === c.id),
);

const KIND_LABELS: Record<string, string> = {
  "allocates-to": "Allocation",
  "deposits-into": "Deposits into",
  "routes-through": "Routes through",
  "routes-fees-to": "Fees routed",
  "holds-role": "Holds role",
  controls: "Controls",
  manages: "Manages",
  "proposes-on": "Proposes on",
  "cancels-on": "Cancels on",
  deploys: "Deploys",
};
const kindLabel = (k: string) => KIND_LABELS[k] ?? k;

const title = graph.title ?? `${slug} — Contract Dependency Graph`;
---

<BaseLayout
  title={`${title} — Yearn Curation`}
  description="Interactive contract dependency graph for the risk assessment."
  ogUrl={`/graph/${slug}/`}
  bare
>
  <div class="graph-shell">
    <div class="graph-topbar">
      <a href={`/report/${slug}/`} class="graph-back">&larr; Risk report</a>
      <div class="graph-title">
        <span class="graph-title-eyebrow">Dependency graph</span>
        <h1>{title.replace(" — Contract Dependency Graph", "")}</h1>
      </div>
      <div class="graph-controls">
        <button id="cy-fit" type="button" title="Fit to view">Fit</button>
        <button id="cy-reset" type="button" title="Re-run layout">Re-layout</button>
      </div>
    </div>

    <div id="cy" aria-label="Contract dependency graph"></div>

    <div class="graph-legend">
      <details>
        <summary>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <circle cx="12" cy="12" r="9"/>
          </svg>
          Legend
        </summary>
        <div class="legend-grid">
          <div class="legend-col">
            <div class="legend-h">Nodes</div>
            {usedCategories.map((c) => (
              <div class="legend-row">
                <span class={`legend-swatch swatch-${c.id}`}></span>
                <span>{c.label}</span>
              </div>
            ))}
          </div>
          <div class="legend-col">
            <div class="legend-h">Edges</div>
            {usedKinds.map((k) => (
              <div class="legend-row">
                <span class={`legend-line line-${k}`}></span>
                <span>{kindLabel(k)}</span>
              </div>
            ))}
          </div>
        </div>
      </details>
    </div>
  </div>

  <script type="application/json" id="cy-data" set:html={JSON.stringify(cyData)}></script>
  <script type="application/json" id="cy-cat-labels" set:html={JSON.stringify(categoryLabels)}></script>

  <script>
    import cytoscape from "cytoscape";
    // @ts-expect-error - no types
    import dagre from "cytoscape-dagre";
    // @ts-expect-error - no types
    import domNode from "cytoscape-dom-node";

    cytoscape.use(dagre);
    cytoscape.use(domNode);

    type CyNode = {
      id: string;
      label: string;
      category: string;
      address: string;
      link: string;
      note: string;
      crossLink: {
        slug: string;
        score: number;
        tier: string;
        color: string;
      } | null;
      inlinedFromSlug: string | null;
    };
    type CyEdge = {
      id: string;
      source: string;
      target: string;
      kind: string;
      label: string;
    };

    const dataEl = document.getElementById("cy-data");
    const catEl = document.getElementById("cy-cat-labels");
    if (!dataEl || !catEl) throw new Error("graph: missing data scripts");
    const data = JSON.parse(dataEl.textContent ?? "{}") as {
      nodes: CyNode[];
      edges: CyEdge[];
    };
    const catLabels = JSON.parse(catEl.textContent ?? "{}") as Record<string, string>;

    const truncAddr = (a: string) =>
      a && a.length > 10 ? `${a.slice(0, 6)}…${a.slice(-4)}` : a;

    function buildCard(n: CyNode): HTMLElement {
      const wrap = document.createElement("div");
      const hasCrossLink = n.crossLink !== null;
      const isInlined = n.inlinedFromSlug !== null;
      const classes = [`graph-card`, `cat-${n.category}`];
      if (hasCrossLink) classes.push("has-crosslink");
      if (isInlined) classes.push("is-inlined");
      wrap.className = classes.join(" ");
      wrap.dataset.nodeId = n.id;

      if (hasCrossLink && n.crossLink) {
        // CSS variable picks up the risk-tier color and drives the border +
        // background tint, so a high-risk dep card looks distinctly different
        // from a low-risk one.
        wrap.style.setProperty("--cl-color", n.crossLink.color);
      }

      const addrFragment = n.address
        ? `<span class="card-addr">${truncAddr(n.address)}</span>`
        : "";
      const riskFragment = hasCrossLink
        ? `<span class="card-risk" style="background:${n.crossLink!.color}">${n.crossLink!.score.toFixed(1)} · ${n.crossLink!.tier.replace(" Risk", "")}</span>`
        : "";
      const extLinkFragment = hasCrossLink && n.link
        ? `<a class="card-extlink" href="${n.link}" target="_blank" rel="noopener noreferrer" title="Open on block explorer">↗</a>`
        : "";
      const eyebrowText = catLabels[n.category] ?? n.category;

      wrap.innerHTML = `
        <div class="card-accent"></div>
        <div class="card-body">
          <div class="card-eyebrow">${eyebrowText}</div>
          <div class="card-title">${escapeHtml(n.label)}</div>
          ${addrFragment || riskFragment ? `<div class="card-meta">${addrFragment}${riskFragment}</div>` : ""}
        </div>
        ${extLinkFragment}
      `;

      if (hasCrossLink) {
        wrap.style.cursor = "pointer";
        wrap.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          if (target.closest(".card-extlink")) return; // let the ↗ link follow its href
          e.stopPropagation();
          window.location.href = `/graph/${n.crossLink!.slug}/`;
        });
      } else if (n.link) {
        wrap.style.cursor = "pointer";
        wrap.addEventListener("click", (e) => {
          e.stopPropagation();
          window.open(n.link, "_blank", "noopener,noreferrer");
        });
      }
      return wrap;
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    const NODE_W = 188;
    const NODE_H = 70;

    const elements: cytoscape.ElementDefinition[] = [
      ...data.nodes.map((n) => ({
        group: "nodes" as const,
        data: { id: n.id, dom: buildCard(n), category: n.category, link: n.link },
      })),
      ...data.edges.map((e) => ({
        group: "edges" as const,
        data: { id: e.id, source: e.source, target: e.target, kind: e.kind, label: e.label },
      })),
    ];

    const flow = new Set(["allocates-to", "deposits-into"]);
    const role = new Set(["holds-role", "controls", "manages"]);
    const gov = new Set(["proposes-on", "cancels-on"]);

    const edgeColor = (k: string) => {
      if (flow.has(k)) return "rgba(110, 231, 183, 0.55)";
      if (role.has(k)) return "rgba(251, 191, 36, 0.5)";
      if (gov.has(k)) return "rgba(167, 139, 250, 0.55)";
      // routes-through participates in flow but renders as a thin hop —
      // muted khaki keeps it visible without competing with the bright
      // money-flow edges or the amber role edges.
      if (k === "routes-through") return "rgba(202, 184, 110, 0.75)";
      // routes-fees-to + deploys: background plumbing (deployment lineage,
      // fee routing) — mid-gray reads on both dark and light themes;
      // pure white at low opacity vanishes on light mode.
      return "rgba(140, 140, 140, 0.6)";
    };
    const edgeStyle = (k: string): cytoscape.LineStyle => {
      if (role.has(k)) return "dashed";
      if (gov.has(k)) return "dotted";
      return "solid";
    };
    const edgeWidth = (k: string) => (flow.has(k) ? 2 : 1.5);

    const cy = cytoscape({
      container: document.getElementById("cy")!,
      elements,
      wheelSensitivity: 0.2,
      minZoom: 0.3,
      maxZoom: 2.5,
      style: [
        {
          selector: "node",
          style: {
            shape: "round-rectangle",
            "background-opacity": 0,
            "border-width": 0,
            width: NODE_W,
            height: NODE_H,
            label: "",
          },
        },
        {
          selector: "edge",
          style: {
            "curve-style": "bezier",
            width: (ele: cytoscape.EdgeSingular) => edgeWidth(ele.data("kind") as string),
            "line-color": (ele: cytoscape.EdgeSingular) => edgeColor(ele.data("kind") as string),
            "line-style": (ele: cytoscape.EdgeSingular) =>
              edgeStyle(ele.data("kind") as string),
            "target-arrow-shape": "triangle-backcurve",
            "target-arrow-color": (ele: cytoscape.EdgeSingular) =>
              edgeColor(ele.data("kind") as string),
            "arrow-scale": 0.85,
            label: (ele: cytoscape.EdgeSingular) => {
              const k = ele.data("kind") as string;
              const lbl = ele.data("label") as string;
              return flow.has(k) ? lbl : "";
            },
            "font-size": 10,
            "font-weight": 500,
            color: "rgba(255,255,255,0.7)",
            "text-background-color": "#0a0b0e",
            "text-background-opacity": 0.95,
            "text-background-padding": "3px",
            "text-background-shape": "round-rectangle",
            "text-rotation": "autorotate",
          },
        },
        {
          selector: "edge.hl",
          style: {
            "line-color": "rgba(110, 167, 255, 0.95)",
            "target-arrow-color": "rgba(110, 167, 255, 0.95)",
            width: 2.5,
            "z-index": 10,
          },
        },
      ],
      layout: {
        name: "dagre",
        // @ts-expect-error - dagre options
        rankDir: "LR",
        nodeSep: 28,
        rankSep: 110,
        edgeSep: 12,
        ranker: "network-simplex",
      },
    });

    // Initialize DOM-node extension AFTER cy is created
    // @ts-expect-error - added by cytoscape-dom-node
    cy.domNode();

    // Re-run layout once DOM nodes are sized (dom-node sometimes
    // measures lazily; one extra fit settles labels & arrows).
    requestAnimationFrame(() => {
      cy.fit(undefined, 80);
    });

    // The DOM cards intercept pointer events, so cytoscape's own node hover
    // never fires. Wire it from the card overlay instead.
    //
    // Hover behavior: walk the *backward* money-flow chain from the hovered
    // node (incoming edges of kind allocates-to / deposits-into / routes-through,
    // recursively) and highlight every edge and ancestor card on that path.
    // Skips role/governance edges so the chain stays focused on capital flow.
    const HL_FLOW_KINDS = new Set([
      "allocates-to",
      "deposits-into",
      "routes-through",
    ]);

    function clearAllHighlights() {
      cy.edges(".hl").removeClass("hl");
      document
        .querySelectorAll(".graph-card.is-hl")
        .forEach((c) => c.classList.remove("is-hl"));
    }

    function highlightAncestors(startId: string) {
      const start = cy.getElementById(startId);
      if (start.length === 0) return;
      const visited = new Set<string>([startId]);
      const queue: cytoscape.NodeSingular[] = [start as cytoscape.NodeSingular];
      while (queue.length) {
        const cur = queue.shift()!;
        const inFlowEdges = cur
          .incomers("edge")
          .filter((ed: cytoscape.EdgeSingular) =>
            HL_FLOW_KINDS.has(ed.data("kind") as string),
          );
        inFlowEdges.forEach((ed: cytoscape.EdgeSingular) => {
          ed.addClass("hl");
          const src = ed.source() as cytoscape.NodeSingular;
          if (!visited.has(src.id())) {
            visited.add(src.id());
            const card = document.querySelector(
              `.graph-card[data-node-id="${CSS.escape(src.id())}"]`,
            );
            if (card) card.classList.add("is-hl");
            queue.push(src);
          }
        });
      }
    }

    const cyContainer = document.getElementById("cy")!;
    cyContainer.addEventListener("mouseover", (e) => {
      const card = (e.target as HTMLElement).closest(".graph-card") as HTMLElement | null;
      if (!card?.dataset.nodeId) return;
      clearAllHighlights();
      card.classList.add("is-hl");
      highlightAncestors(card.dataset.nodeId);
    });
    cyContainer.addEventListener("mouseout", (e) => {
      const card = (e.target as HTMLElement).closest(".graph-card") as HTMLElement | null;
      if (!card?.dataset.nodeId) return;
      clearAllHighlights();
    });

    document.getElementById("cy-fit")?.addEventListener("click", () => {
      cy.fit(undefined, 60);
    });
    document.getElementById("cy-reset")?.addEventListener("click", () => {
      cy.layout({
        name: "dagre",
        // @ts-expect-error - dagre options
        rankDir: "LR",
        nodeSep: 28,
        rankSep: 110,
        edgeSep: 12,
        ranker: "network-simplex",
      }).run();
      requestAnimationFrame(() => cy.fit(undefined, 80));
    });
  </script>
</BaseLayout>

<style is:global>
  /* Escape the 960px container — the graph wants the full viewport */
  body.is-bare main.container {
    max-width: 100vw;
    padding: 0;
  }

  .graph-shell {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    background: #0a0b0e;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size: 24px 24px;
    background-position: 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    height: calc(100vh - 60px); /* fill below site header */
    min-height: 640px;
    overflow: hidden;
  }
  html.light .graph-shell {
    background: #f4f5f8;
    background-image:
      radial-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px);
  }

  #cy {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .graph-topbar {
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    z-index: 5;
    pointer-events: none;
  }
  .graph-topbar > * {
    pointer-events: auto;
  }
  .graph-back {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    background: rgba(20, 22, 28, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  html.light .graph-back {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(0, 0, 0, 0.1);
  }
  .graph-back:hover {
    color: var(--text-primary);
    text-decoration: none;
  }
  .graph-title {
    text-align: center;
    flex: 1;
  }
  .graph-title-eyebrow {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    display: block;
    margin-bottom: 0.15rem;
  }
  .graph-title h1 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }
  .graph-controls {
    display: flex;
    gap: 0.4rem;
  }
  .graph-controls button {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    background: rgba(20, 22, 28, 0.7);
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: color 0.15s, border-color 0.15s;
  }
  html.light .graph-controls button {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(0, 0, 0, 0.1);
  }
  .graph-controls button:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Floating legend */
  .graph-legend {
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 5;
    background: rgba(20, 22, 28, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.78rem;
    max-width: 360px;
  }
  html.light .graph-legend {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(0, 0, 0, 0.08);
  }
  .graph-legend summary {
    cursor: pointer;
    padding: 0.5rem 0.9rem;
    list-style: none;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.66rem;
    font-weight: 600;
    user-select: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .graph-legend summary:hover {
    color: var(--text-primary);
  }
  .graph-legend summary::-webkit-details-marker {
    display: none;
  }
  .graph-legend[open] summary {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .legend-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1.2rem;
    padding: 0.7rem 0.9rem;
  }
  .legend-h {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }
  .legend-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.18rem 0;
    color: var(--text-primary);
    font-size: 0.78rem;
  }
  .legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .swatch-vault       { background: #2b7fff; }
  .swatch-strategy    { background: #f59e0b; }
  .swatch-governance  { background: #ef4444; }
  .swatch-infra       { background: #94a3b8; }
  .swatch-dependency  { background: #a78bfa; }

  .legend-line {
    width: 22px;
    height: 0;
    border-top: 1.5px solid rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }
  .line-allocates-to,
  .line-deposits-into { border-top: 2px solid rgba(110, 231, 183, 0.85); }
  .line-holds-role,
  .line-controls,
  .line-manages       { border-top: 1.5px dashed rgba(251, 191, 36, 0.85); }
  .line-proposes-on,
  .line-cancels-on    { border-top: 1.5px dotted rgba(167, 139, 250, 0.85); }
  .line-routes-through { border-top: 1.5px solid rgba(202, 184, 110, 0.85); }
  .line-routes-fees-to,
  .line-deploys       { border-top: 1.5px solid rgba(140, 140, 140, 0.85); }

  /* === DOM node cards (rendered by cytoscape-dom-node) === */
  .graph-card {
    position: relative;
    width: 188px;
    height: 70px;
    background: rgba(20, 22, 28, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 8px;
    display: flex;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 4px 12px rgba(0, 0, 0, 0.4);
    font-family: system-ui, -apple-system, sans-serif;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .graph-card.has-crosslink {
    border-color: color-mix(in srgb, var(--cl-color, #6ee7b7) 65%, transparent);
    background:
      linear-gradient(
        100deg,
        color-mix(in srgb, var(--cl-color, #6ee7b7) 22%, transparent),
        color-mix(in srgb, var(--cl-color, #6ee7b7) 6%, transparent) 60%,
        rgba(20, 22, 28, 0.96)
      );
  }
  html.light .graph-card.has-crosslink {
    background:
      linear-gradient(
        100deg,
        color-mix(in srgb, var(--cl-color, #6ee7b7) 28%, #ffffff),
        color-mix(in srgb, var(--cl-color, #6ee7b7) 10%, #ffffff) 60%,
        #ffffff
      );
  }
  .graph-card.has-crosslink:hover {
    border-color: var(--cl-color, #6ee7b7);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 0 0 1px color-mix(in srgb, var(--cl-color, #6ee7b7) 75%, transparent) inset,
      0 8px 22px color-mix(in srgb, var(--cl-color, #6ee7b7) 35%, transparent);
  }
  .graph-card.is-inlined {
    opacity: 0.78;
  }
  .graph-card.is-inlined:hover {
