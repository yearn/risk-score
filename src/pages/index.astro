---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScoreBadge from "../components/ScoreBadge.astro";
import { getAllReports } from "../lib/reports";
import { scoreTier } from "../lib/colors";

const reports = getAllReports();
---

<BaseLayout title="Yearn Risk" ogUrl="/" ogImage="/og/default.png">
  <h1>Risk Assessment Reports</h1>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th class="col-icon"></th>
          <th>Protocol</th>
          <th>Token</th>
          <th>Score</th>
          <th>Risk Tier</th>
        </tr>
      </thead>
      <tbody>
        {
          reports.map((r) => (
            <tr onclick={`window.location='/report/${r.slug}/'`}>
              <td class="col-icon">
                <div class="icon-stack">
                  {r.iconUrl ? (
                    <img src={r.iconUrl} alt="" width="24" height="24" class="protocol-icon" loading="lazy" />
                  ) : (
                    <div class="icon-placeholder" />
                  )}
                  {r.chainIconUrl && (
                    <img src={r.chainIconUrl} alt="" width="14" height="14" class="chain-icon" loading="lazy" />
                  )}
                </div>
              </td>
              <td>
                {r.name}
                {r.warning && <span class="warning-tag">&#9888; {r.warning}</span>}
              </td>
              <td class="mono">{r.token}</td>
              <td>
                <ScoreBadge score={r.finalScore} />
              </td>
              <td>{scoreTier(r.finalScore)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1.5rem;
  }
  .col-icon {
    width: 36px;
    padding-right: 0;
  }
  .icon-stack {
    position: relative;
    width: 24px;
    height: 24px;
  }
  .protocol-icon {
    display: block;
    border-radius: 50%;
  }
  .chain-icon {
    position: absolute;
    bottom: -4px;
    right: -6px;
    border-radius: 50%;
    border: 1.5px solid var(--bg-primary);
    background: var(--bg-primary);
  }
  .icon-placeholder {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg-secondary);
  }
  .warning-tag {
    display: inline-block;
    background: #dc2626;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    margin-left: 0.5rem;
    vertical-align: middle;
  }
  .mono {
    font-family: "SF Mono", "Fira Code", monospace;
    font-size: 0.85em;
  }
  tbody tr {
    cursor: pointer;
  }
  tbody tr:hover {
    background: var(--bg-secondary);
  }
  @media (max-width: 640px) {
    table {
      font-size: 0.8rem;
    }
    th,
    td {
      padding: 0.4rem 0.5rem;
    }
  }
</style>
