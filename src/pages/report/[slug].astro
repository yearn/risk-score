---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScoreBadge from "../../components/ScoreBadge.astro";
import ScoreTable from "../../components/ScoreTable.astro";
import { getAllSlugs, getReportBySlug } from "../../lib/reports";


export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const report = getReportBySlug(slug!);
if (!report) return Astro.redirect("/");

const reportIssueUrl = (() => {
  const title = `Report Issue: ${report.name}`;
  const body = [
    `**Report:** ${report.name}`,
    `**Link:** [${report.slug}](https://risk.yearn.farm/report/${report.slug})`,
    `**GitHub:** [${report.slug}.md](https://github.com/yearn/risk-score/blob/master/reports/report/${report.slug}.md)`,
    "",
    "## Issue Description",
    "",
    "<!-- Describe what is wrong or outdated in this report -->",
    "",
  ].join("\n");
  const params = new URLSearchParams({ title, body, labels: "report-issue" });
  return `https://github.com/yearn/risk-score/issues/new?${params}`;
})();
---

<BaseLayout title={`${report.name} — Yearn Risk`}>
  <a href="/" class="back-link">&larr; All Reports</a>

  <div class="report-header">
    <div class="header-top">
      <div class="header-title">
        {report.iconUrl && (
          <img src={report.iconUrl} alt="" width="32" height="32" class="report-protocol-icon" loading="lazy" />
        )}
        <h1>{report.name}</h1>
      </div>
      <ScoreBadge score={report.finalScore} size="large" />
    </div>
    <div class="meta">
      <span>{report.token}</span>
      <span class="sep">/</span>
      <span>{report.chain}</span>
      <span class="sep">/</span>
      <span>{report.date}</span>
    </div>
    <a
      href={`https://github.com/yearn/risk-score/blob/master/reports/report/${report.slug}.md`}
      class="github-link"
      target="_blank"
      rel="noopener noreferrer"
    >
      View full report on GitHub &rarr;
    </a>
  </div>

  <section class="section">
    <h2>Score Breakdown</h2>
    <ScoreTable scores={report.scoreTable} finalScore={report.finalScore} />
  </section>

  <section class="section">
    <h2>Overview</h2>
    <div class="prose" set:html={report.overviewHtml} />
  </section>

  <section class="section">
    <h2>Risk Summary</h2>
    <div class="prose" set:html={report.riskSummaryHtml} />
  </section>

  <details class="full-report">
    <summary class="full-report-toggle">
      <span>Full Report</span>
      <svg class="chevron" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </summary>
    <div class="prose" set:html={report.fullReportHtml} />
  </details>

  <div class="report-footer">
    <a href={reportIssueUrl} class="report-issue-btn" target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/>
        <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Z"/>
      </svg>
      Report Issue
    </a>
  </div>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .report-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .header-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .report-protocol-icon {
    border-radius: 50%;
    flex-shrink: 0;
  }
  h1 {
    font-size: 1.5rem;
  }
  .meta {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .sep {
    margin: 0 0.25rem;
    opacity: 0.4;
  }
  .github-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--brand-blue);
  }
  .github-link:hover {
    text-decoration: underline;
  }
  .section {
    margin-bottom: 2.5rem;
  }
  .section h2 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .full-report {
    margin-bottom: 2.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .full-report-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    user-select: none;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border-radius: 8px;
  }
  .full-report[open] .full-report-toggle {
    border-radius: 8px 8px 0 0;
    border-bottom: 1px solid var(--border);
  }
  .full-report-toggle::-webkit-details-marker {
    display: none;
  }
  .full-report-toggle .chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .full-report[open] .full-report-toggle .chevron {
    transform: rotate(180deg);
  }
  .full-report > .prose {
    padding: 1.25rem;
  }
  .prose :global(p) {
    margin-bottom: 0.75rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.25rem;
  }
  .prose :global(a) {
    color: var(--brand-blue);
  }
  .prose :global(strong) {
    color: var(--text-primary);
  }
  .prose :global(code) {
    background: var(--bg-secondary);
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    font-size: 0.85em;
  }
  .prose :global(pre) {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 0.75rem;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
    display: block;
    overflow-x: auto;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
  }
  .report-footer {
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: center;
  }
  .report-issue-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: color 0.2s, border-color 0.2s;
  }
  .report-issue-btn:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
    text-decoration: none;
  }
</style>
